# QQ Bot 凭证（从 QQ 开放平台 q.qq.com 获取）
QQ_APP_ID=你的AppID
QQ_APP_SECRET=你的AppSecret
QQ_SANDBOX=true

# Claude API（必须）
ANTHROPIC_API_KEY=你的APIKey
ANTHROPIC_BASE_URL=                      # 可选，API 代理地址，留空则使用官方 API
CLAUDE_MODEL=claude-sonnet-4-6           # 默认模型
CLAUDE_TIMEOUT_SECONDS=300               # 超时时间（秒）

# 项目设置
SESSION_TIMEOUT_HOURS=24                 # 会话过期时间
ALLOWED_USERS=                           # QQ openid 白名单，逗号分隔，留空则不限制

# 日志
LOG_LEVEL=INFO
