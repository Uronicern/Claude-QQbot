# QQ Bot 凭证
QQ_APP_ID=你的AppID
QQ_APP_SECRET=你的AppSecret
QQ_SANDBOX=true

# Claude 设置
ANTHROPIC_API_KEY=           # 可选，如果 Claude CLI 已登录则不需要
CLAUDE_MAX_TURNS=10          # 每次对话最大轮数
CLAUDE_TIMEOUT_SECONDS=300   # 超时时间（秒）

# 项目设置
WORKING_DIRECTORY=/path/to/your/projects   # Claude 的工作目录
SESSION_TIMEOUT_HOURS=24                    # 会话过期时间
ALLOWED_USERS=                              # QQ openid 白名单，逗号分隔，留空则不限制

# 日志
LOG_LEVEL=INFO
